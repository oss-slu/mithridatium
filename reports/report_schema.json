{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"required": [
		"mithridatium_version",
		"timestamp_utc",
		"model_path",
		"defense",
		"dataset",
		"results"
	],
	"properties": {
		"mithridatium_version": { "type": "string" },
		"timestamp_utc": { "type": "string" },
		"model_path": { "type": "string" },
		"defense": { "type": "string" },
		"dataset": { "type": "string" },
		"results": { "type": "object" }
	},
	"allOf": [
		{
			"if": {
				"properties": {
					"defense": { "const": "freeeagle" }
				},
				"required": ["defense"]
			},
			"then": {
				"properties": {
					"results": {
						"type": "object",
						"required": [
							"defense",
							"anomaly_metric",
							"anomaly_matrix",
							"tendency_per_target",
							"verdict",
							"thresholds",
							"parameters",
							"dataset"
						],
						"properties": {
							"defense": { "type": "string", "const": "freeeagle" },
							"anomaly_metric": { "type": "number" },
							"anomaly_matrix": {
								"type": "array",
								"items": {
									"type": "array",
									"items": { "type": "number" }
								}
							},
							"tendency_per_target": {
								"type": "array",
								"items": { "type": "number" }
							},
							"verdict": { "type": "string" },
							"thresholds": {
								"type": "object",
								"required": ["anomaly_metric_threshold"],
								"properties": {
									"anomaly_metric_threshold": { "type": "number" }
								},
								"additionalProperties": true
							},
							"parameters": {
								"type": "object",
								"required": [
									"num_classes",
									"inspect_layer_position",
									"optimize_steps",
									"input_shape"
								],
								"properties": {
									"num_classes": { "type": "integer" },
									"inspect_layer_position": { "type": "integer" },
									"optimize_steps": { "type": "integer" },
									"input_shape": {
										"type": "array",
										"items": { "type": "integer" }
									}
								},
								"additionalProperties": true
							},
							"dataset": { "type": "string" }
						},
						"additionalProperties": true
					}
				},
				"required": ["results"]
			}
		}
	],
	"additionalProperties": true
}
